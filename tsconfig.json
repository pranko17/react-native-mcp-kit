{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "node18",
    "target": "es2022",
    "lib": ["es2022"],
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "esModuleInterop": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
